<Window x:Class="OutlastTrialsMod.Views.DirectorySelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OutlastTrialsMod.Localization"
        Title="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=SelectGameDirectoryTitle}"
        Height="192"
        Width="520"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Background="#1a1c23"
        Foreground="#e0e0e0">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="#15171d"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=SelectGameDirectoryTitle}"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Foreground="#e0e0e0"
                       FontSize="12"
                       WindowChrome.IsHitTestVisibleInChrome="True" />
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Style="{StaticResource ChromeButtonStyle}"
                        Content="&#x2014;"
                        Click="MinimizeButton_Click"
                        ToolTip="Minimize" />
                <Button Style="{StaticResource ChromeCloseButtonStyle}"
                        Content="&#x2715;"
                        Click="CloseButton_Click"
                        ToolTip="Close" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Margin="0,0,0,8"
                       TextWrapping="Wrap"
                       Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=SelectGameDirectoryHint}" />

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding GameDirectory, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         Background="#2b2d35"
                         Foreground="#e0e0e0"
                         BorderBrush="#404450"
                         Margin="0,0,8,0" />
                <Button Grid.Column="1"
                        Style="{StaticResource DarkDialogButtonStyle}"
                        Content="..."
                        Width="36"
                        Command="{Binding BrowseCommand}" />
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button Style="{StaticResource DarkDialogButtonStyle}"
                        Width="80"
                        IsDefault="True"
                        Command="{Binding OkCommand}"
                        Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=Ok}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
