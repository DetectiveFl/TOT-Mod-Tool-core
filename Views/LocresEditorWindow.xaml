<Window x:Class="OutlastTrialsMod.Views.LocresEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OutlastTrialsMod.Localization"
        WindowStyle="None"
        Background="#1A1A1A"
        Foreground="#e0e0e0"
        ResizeMode="CanResize"
        MinWidth="820"
        MinHeight="520"
        Width="960"
        Height="640"
        WindowStartupLocation="CenterOwner">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#2b2d35" />
        <SolidColorBrush x:Key="PurpleAccentBrush" Color="#8e44ad" />
        <SolidColorBrush x:Key="PurpleSelectionBrush" Color="#5b2d73" />
        <SolidColorBrush x:Key="PurpleHoverBorderBrush" Color="#b57edc" />
        <SolidColorBrush x:Key="CreateModBackgroundBrush" Color="#0d0e12" />
        <SolidColorBrush x:Key="CreateModHoverBackgroundBrush" Color="#1a1c23" />

        <Style x:Key="LocresSaveButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CreateModBackgroundBrush}" />
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="BorderBrush" Value="{StaticResource PurpleAccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource CreateModHoverBackgroundBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PurpleHoverBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#15171d" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#9b59b6" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LocresDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Foreground" Value="#e0e0e0" />
            <Setter Property="BorderBrush" Value="#32343d" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowBackground" Value="#23252c" />
            <Setter Property="AlternatingRowBackground" Value="#2b2d35" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="RowHeight" Value="32" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="LocresColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#15171d" />
            <Setter Property="Foreground" Value="#e0e0e0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="BorderBrush" Value="{StaticResource PurpleAccentBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="LocresCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource PurpleSelectionBrush}" />
                    <Setter Property="Foreground" Value="#ffffff" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LocresRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#23252c" />
            <Setter Property="Foreground" Value="#e0e0e0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#32343d" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource PurpleSelectionBrush}" />
                    <Setter Property="Foreground" Value="#ffffff" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="#15171d"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TitleText"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Foreground="#e0e0e0"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis"
                       WindowChrome.IsHitTestVisibleInChrome="True" />
            <Button Grid.Column="1"
                    Style="{StaticResource ChromeCloseButtonStyle}"
                    Content="&#x2715;"
                    Click="CloseButton_Click"
                    ToolTip="Close"
                    WindowChrome.IsHitTestVisibleInChrome="True" />
        </Grid>

        <Border Grid.Row="1"
                Background="#1A1A1A"
                Padding="16,12,16,8">
            <Button Style="{StaticResource LocresSaveButtonStyle}"
                    HorizontalAlignment="Left"
                    Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=Save}"
                    Click="SaveButton_Click" />
        </Border>

        <DataGrid x:Name="EntriesGrid"
                  Grid.Row="2"
                  Margin="16,0,16,16"
                  Style="{StaticResource LocresDataGridStyle}"
                  ColumnHeaderStyle="{StaticResource LocresColumnHeaderStyle}"
                  CellStyle="{StaticResource LocresCellStyle}"
                  RowStyle="{StaticResource LocresRowStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Namespace}"
                                    Width="2*"
                                    IsReadOnly="True">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=NamespaceColumn}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Key}"
                                    Width="2*"
                                    IsReadOnly="True">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=KeyColumn}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                    Width="4*"
                                    IsReadOnly="False">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=ValueColumn}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
